{
  "$schema": "../sdkwork-github-workflow/schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-memory",
    "name": "SDKWork Memory",
    "repository": "Sdkwork-Cloud/sdkwork-memory",
    "sourcePath": ".",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-memory",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "app-manifest",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-id",
      "repository": "Sdkwork-Cloud/sdkwork-id",
      "refInput": "SDKWORK_ID_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "refInput": "SDKWORK_UTILS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.30.2",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --frozen-lockfile || echo skip-pnpm-lockfile"
      }
    ],
    "build": [
      {
        "name": "Run SDKWork Memory Phase 1 verification",
        "shell": "pwsh",
        "run": "powershell -ExecutionPolicy Bypass -File tools/verify_phase1.ps1"
      },
      {
        "name": "Run architecture alignment check",
        "shell": "pwsh",
        "run": "node tools/check_sdkwork_memory_architecture_alignment.mjs"
      }
    ],
    "package": [
      {
        "name": "Package Memory server release artifact",
        "shell": "pwsh",
        "run": "node scripts/package-release-artifact.mjs"
      }
    ],
    "validate": [
      {
        "name": "Validate Memory contract and architecture",
        "shell": "pwsh",
        "run": "cargo test --workspace && node tools/check_sdkwork_memory_architecture_alignment.mjs"
      }
    ],
    "sign": [
      {
        "name": "Generate release checksums",
        "shell": "pwsh",
        "run": "node scripts/generate-release-sbom.mjs"
      }
    ],
    "sbom": [
      {
        "name": "Generate SPDX SBOM",
        "shell": "pwsh",
        "run": "node scripts/generate-release-sbom.mjs"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-cloud-container-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["target/release/sdkwork-memory-api-server*"],
      "deploymentProfile": "cloud",
      "runtimeTarget": "container"
    }
  ],
  "security": {
    "artifactAttestations": true,
    "sbomRequired": true,
    "signingRequired": true
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
