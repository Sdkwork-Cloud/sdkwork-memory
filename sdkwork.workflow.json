{
  "$schema": "../sdkwork-github-workflow/schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-memory",
    "name": "SDKWork Memory",
    "repository": "Sdkwork-Cloud/sdkwork-memory",
    "sourcePath": ".",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-memory",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "app-manifest",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-id",
      "repository": "Sdkwork-Cloud/sdkwork-id",
      "refInput": "SDKWORK_ID_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "refInput": "SDKWORK_UTILS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-drive",
      "repository": "Sdkwork-Cloud/sdkwork-drive",
      "refInput": "SDKWORK_DRIVE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.30.2",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Run SDKWork Memory contract verification",
        "shell": "pwsh",
        "run": "powershell -ExecutionPolicy Bypass -File tools/verify_phase1.ps1"
      },
      {
        "name": "Run architecture alignment check",
        "shell": "pwsh",
        "run": "node tools/check_sdkwork_memory_architecture_alignment.mjs"
      },
      {
        "name": "Build and verify Memory PC",
        "shell": "pwsh",
        "run": "pnpm --dir apps/sdkwork-memory-pc check"
      }
    ],
    "package": [
      {
        "name": "Package the selected Memory workflow target",
        "shell": "pwsh",
        "run": "node scripts/package-workflow-target.mjs"
      }
    ],
    "validate": [
      {
        "name": "Validate Memory contract and architecture",
        "shell": "pwsh",
        "run": "pnpm test:release-features && pnpm test:postgres:contract && cargo test --workspace && node tools/check_sdkwork_memory_architecture_alignment.mjs && node scripts/release/workflow-supply-chain-evidence.mjs verify"
      }
    ],
    "sign": [
      {
        "name": "Create a detached artifact signature",
        "shell": "pwsh",
        "run": "node scripts/release/workflow-supply-chain-evidence.mjs sign"
      }
    ],
    "sbom": [
      {
        "name": "Generate byte-bound SBOM, provenance, checksum, and deployment evidence",
        "shell": "pwsh",
        "run": "node scripts/release/workflow-supply-chain-evidence.mjs attest"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-standalone-server-tar-gz",
      "profileBinding": "fixed",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "deployments/artifacts/release/sdkwork-memory-linux-x64-standalone-server.tar.gz",
        ".sdkwork/evidence/linux-x64-standalone-server-tar-gz.json",
        ".sdkwork/evidence/linux-x64-standalone-server-tar-gz/**"
      ],
      "artifactPath": "deployments/artifacts/release/sdkwork-memory-linux-x64-standalone-server.tar.gz",
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    },
    {
      "id": "web-universal-cloud-browser-zip",
      "profileBinding": "fixed",
      "profile": "browser",
      "platform": "web",
      "architecture": "universal",
      "formats": ["zip"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "deployments/artifacts/pc/sdkwork-memory-pc-web-universal-cloud-browser.zip",
        ".sdkwork/evidence/web-universal-cloud-browser-zip.json",
        ".sdkwork/evidence/web-universal-cloud-browser-zip/**"
      ],
      "artifactPath": "deployments/artifacts/pc/sdkwork-memory-pc-web-universal-cloud-browser.zip",
      "deploymentProfile": "cloud",
      "runtimeTarget": "browser"
    },
    {
      "id": "container-x64-cloud-container-oci",
      "profileBinding": "fixed",
      "profile": "container",
      "platform": "container",
      "architecture": "x64",
      "formats": ["oci"],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "deployments/artifacts/release/sdkwork-memory-container-x64-cloud.oci.tar",
        ".sdkwork/evidence/container-x64-cloud-container-oci.json",
        ".sdkwork/evidence/container-x64-cloud-container-oci/**"
      ],
      "artifactPath": "deployments/artifacts/release/sdkwork-memory-container-x64-cloud.oci.tar",
      "deploymentProfile": "cloud",
      "runtimeTarget": "container"
    }
  ],
  "security": {
    "artifactAttestations": true,
    "sbomRequired": true,
    "signingRequired": true
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
