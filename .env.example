# Safe checked-in example for SDKWork Memory local development.
# Copy to `.env` and replace credentials before running `pnpm dev`.
# For PostgreSQL development, copy `.env.postgres.example` instead.

# === Runtime profile ===
SDKWORK_MEMORY_ENVIRONMENT=development
SDKWORK_MEMORY_CONFIG_PROFILE=dev
SDKWORK_MEMORY_DEPLOYMENT_PROFILE=standalone
SDKWORK_MEMORY_SERVICE_LAYOUT=unified-process
SDKWORK_MEMORY_RUNTIME_TARGET=container

# === Local bind ===
SDKWORK_MEMORY_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:8080

# === Development-only auth bypass ===
# Enables in-process dev identity without real IAM tokens.
# MUST be false in any shared or production environment.
SDKWORK_MEMORY_DEV_AUTH_BYPASS=true

# === Dev identity defaults (only honored when DEV_AUTH_BYPASS=true) ===
# These are NOT fixed IAM identities for shared environments (per ENVIRONMENT_SPEC §6.1).
# They are local dev defaults used solely by the bypass shim.
SDKWORK_MEMORY_TENANT_ID=100001
SDKWORK_MEMORY_USER_ID=9001

# === Snowflake node id (single-node dev only) ===
SDKWORK_MEMORY_SNOWFLAKE_NODE_ID=1

# === Database (SQLite in-memory for quick dev) ===
SDKWORK_MEMORY_DATABASE_URL=sqlite::memory:

# === Tenant quotas (0 = unlimited). See PERFORMANCE_SPEC.md. ===
# SDKWORK_MEMORY_MAX_RECORDS_PER_SPACE=100000
# SDKWORK_MEMORY_MAX_SPACES_PER_USER=100

# === API rate limiting (per-instance, not distributed) ===
# Maximum request body size in bytes (default: 1048576 = 1 MiB).
# SDKWORK_MEMORY_MAX_BODY_BYTES=1048576
# Maximum concurrent in-flight requests (default: 256).
# SDKWORK_MEMORY_MAX_CONCURRENCY=256

# === Outbox delivery ===
# Delivery mode: "log" (default) or "http".
# SDKWORK_MEMORY_OUTBOX_DELIVERY_MODE=log
# Webhook URL for HTTP delivery mode.
# SDKWORK_MEMORY_OUTBOX_DELIVERY_URL=
# Delivery timeout in seconds (default: 10).
# SDKWORK_MEMORY_OUTBOX_DELIVERY_TIMEOUT_SECS=10
# Maximum delivery retries before marking event as failed (default: 5).
# SDKWORK_MEMORY_OUTBOX_MAX_RETRIES=5
# Poll interval for pending outbox events in seconds (default: 2).
# SDKWORK_MEMORY_OUTBOX_POLL_INTERVAL_SECS=2
# Stale processing requeue threshold in seconds (default: 300).
# SDKWORK_MEMORY_OUTBOX_STALE_PROCESSING_SECS=300

# === Background workers ===
# Poll interval for learning job worker in seconds (default: 2).
# SDKWORK_MEMORY_JOB_POLL_INTERVAL_SECS=2
# Poll interval for eval run worker in seconds (default: 5).
# SDKWORK_MEMORY_EVAL_POLL_INTERVAL_SECS=5
# Provider health probe interval in seconds (default: 60).
# SDKWORK_MEMORY_PROVIDER_HEALTH_PROBE_SECS=60

# === Optional OpenTelemetry OTLP export (release image built with `otel` feature). ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# === Access token (required for production; obtain from IAM) ===
# SDKWORK_ACCESS_TOKEN=<jwt-access-token>
