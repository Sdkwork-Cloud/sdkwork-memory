# Safe checked-in example for SDKWork Memory local development.
# Copy to `.env` and replace credentials before running `pnpm dev`.

SDKWORK_MEMORY_ENVIRONMENT=development
SDKWORK_MEMORY_CONFIG_PROFILE=dev
SDKWORK_MEMORY_DEV_AUTH_BYPASS=true
SDKWORK_MEMORY_TENANT_ID=1001
SDKWORK_MEMORY_USER_ID=9001
SDKWORK_MEMORY_SNOWFLAKE_NODE_ID=1
SDKWORK_MEMORY_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:8080
SDKWORK_MEMORY_DATABASE_URL=sqlite::memory:

# PostgreSQL alternative (uncomment and configure for production-like dev):
# SDKWORK_MEMORY_DATABASE_ENGINE=postgresql
# SDKWORK_MEMORY_DATABASE_HOST=127.0.0.1
# SDKWORK_MEMORY_DATABASE_PORT=5432
# SDKWORK_MEMORY_DATABASE_NAME=sdkwork_memory_dev
# SDKWORK_MEMORY_DATABASE_SCHEMA=public
# SDKWORK_MEMORY_DATABASE_USERNAME=sdkwork_memory_dev
# SDKWORK_MEMORY_DATABASE_PASSWORD=change-me
# SDKWORK_MEMORY_DATABASE_SSL_MODE=disable
# SDKWORK_MEMORY_DATABASE_MAX_CONNECTIONS=10
