# Production deployments MUST use PostgreSQL and MUST NOT enable DEV_AUTH_BYPASS.
# Database URLs are injected via environment providers or secrets.
# Fixed IAM identity MUST NOT be defined in topology env files (per ENVIRONMENT_SPEC §6.1).

SDKWORK_MEMORY_DEPLOYMENT_PROFILE=standalone
SDKWORK_MEMORY_ENVIRONMENT=production
SDKWORK_MEMORY_CONFIG_PROFILE=production
SDKWORK_MEMORY_RUNTIME_TARGET=container
SDKWORK_MEMORY_PROFILE_ID=standalone.production

SDKWORK_MEMORY_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:8080
SDKWORK_MEMORY_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:8080
SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_BIND=0.0.0.0:8080
SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:8080
SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_BIND=0.0.0.0:8080
SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_URL=http://127.0.0.1:8080
SDKWORK_MEMORY_APPLICATION_APP_HTTP_BIND=0.0.0.0:8080
SDKWORK_MEMORY_APPLICATION_APP_HTTP_URL=http://127.0.0.1:8080

# Database URL is injected via SDKWORK_MEMORY_DATABASE_URL secret/env at runtime.
# IAM Database URL is injected via SDKWORK_IAM_DATABASE_URL secret/env at runtime.
SDKWORK_MEMORY_DATABASE_AUTO_MIGRATE=false
# SDKWORK_MEMORY_SNOWFLAKE_NODE_ID is intentionally NOT set in production.
# The service uses database-backed node_id allocation via sdkwork_node_registry,
# which automatically assigns unique node IDs per instance. Setting a fixed
# node_id here would cause ID collisions in multi-instance deployments.
