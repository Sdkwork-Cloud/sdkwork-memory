# Production deployments MUST use PostgreSQL and MUST NOT enable DEV_AUTH_BYPASS.
# Database URLs are injected via Kubernetes secrets or environment providers.
# Fixed IAM identity MUST NOT be defined in topology env files (per ENVIRONMENT_SPEC §6.1).

SDKWORK_MEMORY_DEPLOYMENT_PROFILE=cloud
SDKWORK_MEMORY_ENVIRONMENT=production
SDKWORK_MEMORY_CONFIG_PROFILE=production
SDKWORK_MEMORY_RUNTIME_TARGET=container
SDKWORK_MEMORY_PROFILE_ID=cloud.production

SDKWORK_MEMORY_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:8080
SDKWORK_MEMORY_APPLICATION_PUBLIC_HTTP_URL=http://sdkwork-memory-standalone-gateway.sdkwork-memory.svc.cluster.local:8080
SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_BIND=0.0.0.0:8081
SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_URL=http://sdkwork-memory-open-api.sdkwork-memory.svc.cluster.local:8081
SDKWORK_MEMORY_APPLICATION_APP_HTTP_BIND=0.0.0.0:8082
SDKWORK_MEMORY_APPLICATION_APP_HTTP_URL=http://sdkwork-memory-app-api.sdkwork-memory.svc.cluster.local:8082
SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_BIND=0.0.0.0:8083
SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_URL=http://sdkwork-memory-backend-api.sdkwork-memory.svc.cluster.local:8083

# Database URL is injected via SDKWORK_MEMORY_DATABASE_URL secret/env at runtime.
# IAM Database URL is injected via SDKWORK_IAM_DATABASE_URL secret/env at runtime.
SDKWORK_MEMORY_DATABASE_AUTO_MIGRATE=false
