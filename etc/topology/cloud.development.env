# Development profile allows DEV_AUTH_BYPASS for local iteration but MUST NOT
# ship to shared environments. Fixed IAM identity MUST NOT be defined here
# (per ENVIRONMENT_SPEC §6.1); use real IAM dev tokens instead.

SDKWORK_MEMORY_DEPLOYMENT_PROFILE=cloud
SDKWORK_MEMORY_ENVIRONMENT=development
SDKWORK_MEMORY_CONFIG_PROFILE=dev
SDKWORK_MEMORY_RUNTIME_TARGET=container
SDKWORK_MEMORY_PROFILE_ID=cloud.development

SDKWORK_MEMORY_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:8080
SDKWORK_MEMORY_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_BIND=127.0.0.1:8081
SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_MEMORY_APPLICATION_APP_HTTP_BIND=127.0.0.1:8082
SDKWORK_MEMORY_APPLICATION_APP_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_BIND=127.0.0.1:8083
SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com

# Development-only auth bypass; MUST be false in production.
SDKWORK_MEMORY_DEV_AUTH_BYPASS=false
SDKWORK_MEMORY_SNOWFLAKE_NODE_ID=1
SDKWORK_MEMORY_DATABASE_URL=sqlite::memory:
VITE_SDKWORK_MEMORY_APPLICATION_PUBLIC_HTTP_URL=https://api-dev.sdkwork.com
SDKWORK_MEMORY_PLATFORM_API_GATEWAY_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_MEMORY_PLATFORM_API_GATEWAY_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_MEMORY_APPLICATION_BACKEND_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_MEMORY_APPLICATION_OPEN_HTTP_URL=https://api-dev.sdkwork.com
VITE_SDKWORK_MEMORY_APPLICATION_APP_HTTP_URL=https://api-dev.sdkwork.com
