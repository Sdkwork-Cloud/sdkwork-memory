# PostgreSQL development example for SDKWork Memory.
# Copy to `.env.postgres` and replace credentials before running with PostgreSQL backend.
# Unified workspace PostgreSQL profile. See sdkwork-specs/ENVIRONMENT_SPEC.md §7.1.

# === Runtime profile ===
SDKWORK_MEMORY_ENVIRONMENT=development
SDKWORK_MEMORY_CONFIG_PROFILE=dev
SDKWORK_MEMORY_DEPLOYMENT_PROFILE=standalone
SDKWORK_MEMORY_SERVICE_LAYOUT=unified-process
SDKWORK_MEMORY_RUNTIME_TARGET=container

# === Local bind ===
SDKWORK_MEMORY_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:8080

# === Development-only auth bypass ===
SDKWORK_MEMORY_DEV_AUTH_BYPASS=true

# === Dev identity defaults (only honored when DEV_AUTH_BYPASS=true) ===
SDKWORK_MEMORY_TENANT_ID=100001
SDKWORK_MEMORY_USER_ID=9001

# === Snowflake node id (single-node dev only) ===
SDKWORK_MEMORY_SNOWFLAKE_NODE_ID=1

# === Unified claw PostgreSQL identity ===
SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=10

SDKWORK_CLAW_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_ADMIN_PORT=5432
SDKWORK_CLAW_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_CLAW_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_CLAW_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_CLAW_DATABASE_ADMIN_SSL_MODE=disable

# === Tenant quotas (0 = unlimited). See PERFORMANCE_SPEC.md. ===
# SDKWORK_MEMORY_MAX_RECORDS_PER_SPACE=100000
# SDKWORK_MEMORY_MAX_SPACES_PER_USER=100

# === Database connection pool tuning ===
# SDKWORK_MEMORY_DB_MAX_CONNECTIONS=20
# SDKWORK_MEMORY_DB_MIN_CONNECTIONS=5

# === API rate limiting (per-instance) ===
# SDKWORK_MEMORY_MAX_BODY_BYTES=1048576
# SDKWORK_MEMORY_MAX_CONCURRENCY=256

# === Outbox delivery ===
# SDKWORK_MEMORY_OUTBOX_DELIVERY_MODE=log
# SDKWORK_MEMORY_OUTBOX_MAX_RETRIES=5
# SDKWORK_MEMORY_OUTBOX_POLL_INTERVAL_SECS=2

# === Optional OpenTelemetry OTLP export (release image built with `otel` feature). ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# === Access token (required for production; obtain from IAM) ===
# SDKWORK_ACCESS_TOKEN=<jwt-access-token>
